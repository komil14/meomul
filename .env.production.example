# ──────────────────────────────────────────────────────────────
# Meomul API — Production Environment Variables
# Copy to .env on your production server and fill in all values.
# ──────────────────────────────────────────────────────────────

# Environment — MUST be "production"
NODE_ENV=production

# ── Server ────────────────────────────────────────────────────
PORT_API=3001
PORT_BATCH=3003

# ── MongoDB ───────────────────────────────────────────────────
# Use a SEPARATE production database — NOT the same as dev!
MONGO_PROD=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/MeomulProd?retryWrites=true&w=majority

# ── Auth (REQUIRED) ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=<generate-a-64-byte-random-secret>

# Access token lifetime (short-lived; refresh tokens handle session persistence)
JWT_EXPIRES_IN=15m

# ── Cookie Signing (REQUIRED) ────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
COOKIE_SECRET=<generate-a-32-byte-random-secret>

# ── CORS (REQUIRED) ──────────────────────────────────────────
# Your frontend's production URL — without trailing slash
FRONTEND_URL=https://meomul.com

# ── Redis (optional) ─────────────────────────────────────────
# If set, enables Redis-backed cache + Socket.IO horizontal scaling
# REDIS_URL=redis://<host>:6379
# REDIS_SOCKET_ENABLED=true
