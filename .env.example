# ──────────────────────────────────────────────────────────────
# Meomul API + Batch — Environment Variables
# Copy this file to .env and fill in values.
# ──────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development                    # development | production
PORT_API=3001                           # API server port

# ── Database ──────────────────────────────────────────────────
MONGO_DEV=mongodb://localhost:27017/meomul-dev   # Dev MongoDB URI
MONGO_PROD=                                       # Production MongoDB URI (Atlas etc.)
MONGO_SLOW_QUERY_LOG=false                        # Log slow queries (true|false)
MONGO_SLOW_QUERY_MS=200                           # Slow query threshold in ms (default 300)

# ── Authentication ────────────────────────────────────────────
JWT_SECRET=                             # REQUIRED — min 32 chars (openssl rand -hex 32)
JWT_EXPIRES_IN=15m                      # Access token lifetime (e.g. 15m, 1h)
COOKIE_SECRET=                          # REQUIRED in production — min 32 chars (openssl rand -hex 32)

# ── Redis (optional) ─────────────────────────────────────────
REDIS_URL=                              # Redis connection URL (e.g. redis://localhost:6379)
REDIS_SOCKET_ENABLED=true               # Enable Redis adapter for Socket.IO (true|false)

# ── CORS / Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000      # Frontend origin URL
SOCKET_CORS_ORIGINS=                    # Additional comma-separated CORS origins for sockets

# ── Batch Alerting ───────────────────────────────────────────
BATCH_ALERT_WEBHOOK_URL=                # Slack/Discord/PagerDuty webhook — fires on cron failure
